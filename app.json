{
  "expo": {
    "name": "Football Sudoku",
    "slug": "footballsudoku",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "footballsudoku",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.footballsudoku.app",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "We use your advertising identifier to show you relevant ads and measure ad performance. You can change this at any time in your device settings.",
        "NSPhotoLibraryUsageDescription": "Allow access to your photo library to set a custom badge for your club.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.footballsudoku.app",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "plugins": [
      [
        "expo-router"
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-tracking-transparency",
      ["expo-image-picker", {
        "cameraPermission": false,
        "microphonePermission": false
      }],
      "expo-apple-authentication",
      "./plugins/withPrivacyManifest",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2822076056747898~5125064351",
          "iosAppId": "ca-app-pub-2822076056747898~5608280084"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cb4eea7b-515b-44da-893a-f5e6b60269fa"
      }
    }
  }
}
