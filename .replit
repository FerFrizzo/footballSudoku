entrypoint = "README.md"
modules = ["nodejs-22"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["revenuecat:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run expo:dev"
waitForPort = 8081
ensurePreviewReachable = "/status"

[userenv]

[userenv.shared]
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_dZPmXsloIAzJCXvAyruBLxMjuvx"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_MKjSwvXvzMLVUZRixtiBBuEOgKt"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_GuVBaSxaPsJxxlswADAIIdWBxLZ"
REVENUECAT_PROJECT_ID = "proj85e7ca90"
REVENUECAT_TEST_STORE_APP_ID = "appeae50712f5"
REVENUECAT_APPLE_APP_STORE_APP_ID = "appde241a401b"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "app19a4fe21d5"
